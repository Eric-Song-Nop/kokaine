{
  "name": "@kokaine/cli",
  "version": "0.1.0",
  "description": "npm-native build, development, and diagnostics tooling for Kokaine",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Eric-Song-Nop/kokaine.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/Eric-Song-Nop/kokaine/tree/main/packages/cli#readme",
  "bugs": {
    "url": "https://github.com/Eric-Song-Nop/kokaine/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "bin": {
    "kokaine": "bin/kokaine.js"
  },
  "exports": {
    ".": "./src/index.js",
    "./vite": "./src/vite.js"
  },
  "files": [
    "bin",
    "src",
    "compiler-releases.json",
    "README.md"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.js"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "semver": "^7.8.5",
    "vite": "^8.1.5"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
