// A retained browser callback can use only capabilities which the DOM adapter
// explicitly reinstalls at the later host turn. In particular this row is not
// open: a lexical application handler surrounding `mount` has already returned
// when JavaScript delivers an event and cannot safely be reconstructed.
//
// `pure` includes Koka's modeled `exn`/`div`: the event boundary reports an
// uncaught Koka exception and still unwinds its reactive batch. Native throws
// from an extern declared only as `ui` violate that extern's effect contract;
// adapters must translate them at the innermost FFI boundary (as DOM does).
local alias kokaine/html/callback-effect[36,1,36,68] :: E = <(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/reactive/effects/signal-read :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/reactive/effects/signal-write :: (E, V) -> V)>,(std/core/ui :: X),((kokaine/async/effects/async :: E) == 1 <(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/async/effects/async-await :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/async/effects/async-cancel :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/async/effects/async-ioc :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/async/effects/async-ownership :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/async/effects/discontinue :: (E, V) -> V)>>),((std/core/pure :: E) == 1 <(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>,(std/core/types/div :: X)>)> = 2;
