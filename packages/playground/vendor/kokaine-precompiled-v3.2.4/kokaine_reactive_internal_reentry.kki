// Retirement marks the captured frame dead before finalizers run. A parked
// async strand still has to be discontinued so its lexical `finally` clauses
// unwind, but it must not gain a fresh registration or host batch. Keep this
// path private to runtime-owned cancellation and restore only the already
// captured reactive handlers/context.
fun run-retirement-reentry[72,5,72,26] : forall<a,(e :: E)> (value : (kokaine/reactive/internal/model/reentry :: E -> V)<(e :: E)>, action : () -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/reactive/effects/signal-read :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/reactive/effects/signal-write :: (E, V) -> V)>,(std/core/pure :: E)|(e :: E)> a) -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>|(e :: E)> a;
// The application runner surrounds the complete cancellation turn. It is the
// explicit capability which reinstalls application handlers after the host
// callback that initiated retirement has outlived their dynamic extent.
pub fun run-application-retirement-reentry[90,9,90,42] : forall<a,(e :: E),(e1 :: E)> (runner : (kokaine/reactive/internal/application-runner/app-runner :: (E, E) -> V)<<(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>|(e :: E)>,(e1 :: E)>, value : (kokaine/reactive/internal/model/reentry :: E -> V)<(e :: E)>, action : () -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/reactive/effects/signal-read :: (E, V) -> V)>,(std/core/types/handled :: ((E, V) -> V) -> X)<(kokaine/reactive/effects/signal-write :: (E, V) -> V)>,(std/core/pure :: E)|(e :: E)> a) -> (e1 :: E) a;
 
