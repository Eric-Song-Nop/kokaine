// An `:error<a>` type represents a first-class exception result as a `:result<a,exception>`.
local alias std/core/exn/error[65,1,65,40]<a> :: V -> V = (std/core/types/result :: (V, V) -> V)<a,std/core/exn/exception> = 1;
 
