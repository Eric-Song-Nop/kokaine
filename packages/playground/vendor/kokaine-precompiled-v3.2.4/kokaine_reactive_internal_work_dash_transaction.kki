// The front is stored in dequeue order and the back in reverse append order.
// Reversing an exhausted back list amortizes across all preceding appends.
pub type deque[26,1,30,3] <a> :: V -> V {
  pub con Deque[27,3,27,7](deque-front: (std/core/types/list :: V -> V)<a>, deque-back: (std/core/types/list :: V -> V)<a>){0,2,8} : forall<a> (deque-front : (std/core/types/list :: V -> V)<a>, deque-back : (std/core/types/list :: V -> V)<a>) -> (deque :: V -> V)<a> = 1;
};
