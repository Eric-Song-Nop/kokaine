};
// Structural adapters which join an outer bootstrap transaction cannot
// publish independently. They enlist a fallible preparation, a total state
// publication, and a rollback action in the outer transaction instead.
pub type work-publication[103,1,108,3] <(e :: E)> :: E -> V {
  pub con Work-publication[104,3,104,18](publication-prepare: () -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>|(e :: E)> (), publication-publish: () -> (), publication-rollback: () -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>|(e :: E)> ()){0,3,8} : forall<(e :: E)> (publication-prepare : () -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>|(e :: E)> (), publication-publish : () -> (), publication-rollback : () -> <(std/core/types/handled :: ((E, V) -> V) -> X)<(std/core/exn/exn :: (E, V) -> V)>|(e :: E)> ()) -> (work-publication :: E -> V)<(e :: E)> = 1;
};
 
